{
  "name": "@coroboros/pdf-cleaner",
  "version": "1.0.3",
  "description": "Strip metadata and links from PDFs locally — no upload, no tracking.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "pdf-cleaner": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "pnpm build && node bench/pdf-cleaner.bench.mjs",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "keywords": [
    "coroboros",
    "pdf",
    "pdf-cleaner",
    "privacy",
    "metadata",
    "hyperlinks",
    "annotations",
    "cli",
    "typescript",
    "node"
  ],
  "author": "Coroboros <ob@coroboros.com> (https://github.com/coroboros)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coroboros/pdf-cleaner.git"
  },
  "bugs": {
    "url": "https://github.com/coroboros/pdf-cleaner/issues"
  },
  "homepage": "https://github.com/coroboros/pdf-cleaner#readme",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.3",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "fast-check": "^4.8.0",
    "mitata": "^1.0.34",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
